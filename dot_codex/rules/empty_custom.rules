# git
prefix_rule(pattern=["git", "add"], decision="allow")
prefix_rule(pattern=["git", "commit", "-m"], decision="allow")
prefix_rule(pattern=["git", "push"], decision="allow")
prefix_rule(pattern=["git", "pull"], decision="allow")
prefix_rule(pattern=["git", "fetch"], decision="allow")

# github
prefix_rule(pattern=["gh", "api"], decision="allow")
prefix_rule(pattern=["gh", "auth", "status"], decision="allow")
prefix_rule(pattern=["gh", "pr", "list"], decision="allow")
prefix_rule(pattern=["gh", "pr", "view"], decision="allow")
prefix_rule(pattern=["gh", "pr", "create"], decision="allow")
prefix_rule(pattern=["gh", "pr", "comment"], decision="allow")
prefix_rule(pattern=["gh", "pr", "comment", "create"], decision="allow")
prefix_rule(pattern=["gh", "pr", "comment", "delete"], decision="allow")
prefix_rule(pattern=["gh", "pr", "comment", "update"], decision="allow")
prefix_rule(pattern=["gh", "pr", "comment", "list"], decision="allow")
prefix_rule(pattern=["gh", "repo", "view"], decision="allow")
prefix_rule(pattern=["gh", "issue", "list"], decision="allow")
prefix_rule(pattern=["gh", "issue", "view"], decision="allow")
prefix_rule(pattern=["gh", "issue", "create"], decision="allow")
prefix_rule(pattern=["gh", "issue", "comment"], decision="allow")
prefix_rule(pattern=["gh", "issue", "comment", "create"], decision="allow")
prefix_rule(pattern=["gh", "issue", "comment", "delete"], decision="allow")
prefix_rule(pattern=["gh", "issue", "comment", "update"], decision="allow")
prefix_rule(pattern=["gh", "issue", "comment", "list"], decision="allow")

# python uv
prefix_rule(pattern=["uv", "run", "pytest"], decision="allow")
prefix_rule(pattern=["uv", "run", "lint-imports"], decision="allow")
prefix_rule(pattern=["uv", "run", "ruff", "check", "."], decision="allow")
prefix_rule(pattern=["uv", "run", "python"], decision="allow")
prefix_rule(pattern=["uv", "run", "ruff", "check"], decision="allow")
